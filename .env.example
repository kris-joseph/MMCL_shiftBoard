# LibCal API Credentials
# Copy this file to .env and fill in your actual credentials
# Never commit .env to version control

LIBCAL_CLIENT_ID=your_client_id_here
LIBCAL_CLIENT_SECRET=your_client_secret_here

# Privacy Mode
# Set to "true" for Phase 1 (public GitHub Pages) - masks patron names/emails
# Set to "false" for Phase 2 (private Docker deployment) - shows full information
PRIVACY_MODE=true